# Configuration Supabase
# Remplacez ces valeurs par vos propres clés Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon
VITE_SUPABASE_SERVICE_KEY=votre_cle_service_role

# Configuration API (backup si Supabase n'est pas disponible)
VITE_API_URL=http://localhost:3001/api

# Configuration de l'application
VITE_APP_NAME=NOLI Assurance
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Plateforme de comparaison d'assurances
VITE_APP_URL=http://localhost:5173

# Configuration des emails
VITE_EMAIL_FROM=noreply@noliassurance.com
VITE_EMAIL_SUPPORT=support@noliassurance.com
VITE_EMAIL_CONTACT=contact@noliassurance.com

# Configuration des features
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_PHONE_VERIFICATION=true
VITE_ENABLE_MFA=false
VITE_ENABLE_QUOTE_COMPARISON=true
VITE_ENABLE_ONLINE_PAYMENT=true

# Configuration des limites et tarifs
VITE_MAX_FILE_SIZE=10485760  # 10MB en octets
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.png,.jpeg
VITE_MIN_PREMIUM_AMOUNT=10
VITE_MAX_PREMIUM_AMOUNT=10000
VITE_DEFAULT_CURRENCY=EUR

# Configuration des délais (en jours)
VITE_QUOTE_VALIDITY_DAYS=30
VITE_POLICY_RENEWAL_REMINDER_DAYS=15
VITE_SESSION_TIMEOUT_HOURS=24

# Configuration du développement
VITE_DEBUG=false
VITE_MOCK_DATA=false
VITE_DEV_MODE=true

# Services externes (optionnel)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://...

# Sécurité
VITE_PASSWORD_MIN_LENGTH=8
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_LOCKOUT_DURATION_MINUTES=15
