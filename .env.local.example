# Variables d'environnement pour les tests d'authentification
# Copiez ce fichier en .env.local et remplacez les valeurs par vos vraies clés

# URL de votre projet Supabase
SUPABASE_URL=https://your-project.supabase.co

# Clé API anonyme de votre projet Supabase
SUPABASE_ANON_KEY=your-anon-key-here

# Clé API de service (ne jamais exposer côté client)
# SUPABASE_SERVICE_KEY=your-service-key-here

# URL de l'API REST Supabase
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Mode mock pour le développement
VITE_MOCK_DATA=false