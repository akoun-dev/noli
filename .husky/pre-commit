#!/usr/bin/env sh
echo "🔍 DEBUG: Husky pre-commit hook started"
echo "🔍 DEBUG: Current working directory: $(pwd)"
echo "🔍 DEBUG: Git staged files:"
git diff --cached --name-only
echo "🔍 DEBUG: Git status:"
git status --porcelain

echo "🔍 Running pre-commit hooks..."

# Run lint-staged
npx lint-staged

# Check for console.log statements (excluding test files and husky scripts)
echo "🚫 Checking for console.log statements..."
echo "🔍 DEBUG: Checking for console.log in staged files..."
STAGED_FILES=$(git diff --cached --name-only)
echo "🔍 DEBUG: Staged files list:"
echo "$STAGED_FILES"
if echo "$STAGED_FILES" | xargs grep -l "console\.log" 2>/dev/null | grep -v "\.test\." | grep -v "\.spec\." | grep -v "\.husky/"; then
  echo "❌ Found console.log statements in staged files. Please remove them before committing."
  echo "💡 Use logger instead of console.log for debugging."
  exit 1
else
  echo "🔍 DEBUG: No console.log found or error occurred during search"
fi

# Check for TODO comments without ticket numbers (excluding husky scripts)
echo "📝 Checking TODO comments..."
echo "🔍 DEBUG: Checking for TODO comments in staged files..."
if echo "$STAGED_FILES" | xargs grep -n "TODO" 2>/dev/null | grep -v "TODO-[0-9]\+" | grep -v "TODO(#" | grep -v "\.husky/" ; then
  echo "⚠️  Found TODO comments without ticket numbers."
  echo "💡 Please use TODO-XXXX or TODO(#XXXX) format where XXXX is the ticket number."
else
  echo "🔍 DEBUG: No TODO comments found or error occurred during search"
fi

# Check for large files (>1MB)
echo "📏 Checking for large files..."
echo "🔍 DEBUG: Checking for large files in staged files..."
large_files=$(echo "$STAGED_FILES" | xargs du -k 2>/dev/null | awk '$1 > 1024 {print $2}')
if [ ! -z "$large_files" ]; then
  echo "⚠️  Large files detected:"
  echo "$large_files"
  echo "💡 Consider using Git LFS for large binary files."
else
  echo "🔍 DEBUG: No large files found or error occurred during search"
fi

# Run quick type check
echo "🔍 Running TypeScript type check..."
npx tsc --noEmit --skipLibCheck

# Check if package-lock.json is up to date
echo "📦 Checking package-lock.json..."
if [ -f "package.json" ] && [ -f "package-lock.json" ]; then
  npm ci --dry-run > /dev/null 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ package-lock.json is out of sync with package.json"
    echo "💡 Run 'npm install' to update package-lock.json"
    exit 1
  fi
fi

# Check for sensitive data patterns
echo "🔒 Checking for sensitive data..."
echo "🔍 DEBUG: Sensitive data check temporarily disabled for debugging"
echo "🔍 DEBUG: TODO: Re-enable sensitive data check with proper filtering"

if echo "$STAGED_FILES" | xargs grep -i "secret.*=" 2>/dev/null | grep -v "\.example" | grep -v "\.template" | grep -v "\.env\." | grep -v "supabase/config.toml"; then
  echo "❌ Found potential sensitive data in staged files:"
  echo "$SENSITIVE_FILES"
  echo "💡 Make sure sensitive data is properly secured!"
  exit 1
fi

if echo "$STAGED_FILES" | xargs grep -i "token.*=" 2>/dev/null | grep -v "\.example" | grep -v "\.template" | grep -v "\.env\." | grep -v "supabase/config.toml"; then
  echo "❌ Found potential sensitive data in staged files:"
  echo "$SENSITIVE_FILES"
  echo "💡 Make sure sensitive data is properly secured!"
  exit 1
fi

if echo "$STAGED_FILES" | xargs grep -i "api_key.*=" 2>/dev/null | grep -v "\.example" | grep -v "\.template" | grep -v "\.env\." | grep -v "supabase/config.toml"; then
  echo "❌ Found potential sensitive data in staged files:"
  echo "$SENSITIVE_FILES"
  echo "💡 Make sure sensitive data is properly secured!"
  exit 1
fi

if echo "$STAGED_FILES" | xargs grep -i "private_key.*=" 2>/dev/null | grep -v "\.example" | grep -v "\.template" | grep -v "\.env\." | grep -v "supabase/config.toml"; then
  echo "❌ Found potential sensitive data in staged files:"
  echo "$SENSITIVE_FILES"
  echo "💡 Make sure sensitive data is properly secured!"
  exit 1
fi

echo "✅ Pre-commit checks passed!"
