#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "📝 Validating commit message..."

# Run commitlint
npx --no -- commitlint --edit ${1}

# Additional custom validations
message=$(cat "$1")

# Check for minimum length
if [ ${#message} -lt 10 ]; then
  echo "❌ Commit message is too short (minimum 10 characters)."
  exit 1
fi

# Check for proper issue reference in non-initial commits
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  # Not the first commit
  if [[ ! "$message" =~ ^(init|Initial|chore\(deps\)|docs\(changelog\)) ]]; then
    if [[ ! "$message" =~ (#[0-9]+|TODO-[0-9]+|fixes|closes|resolves) ]]; then
      echo "⚠️  Consider adding a ticket reference (e.g., feat: add login form #123)"
    fi
  fi
fi

# Check for common mistakes
if [[ "$message" =~ (wip|WIP|fixup|squash) ]]; then
  echo "❌ WIP/fixup commits should not be pushed to main/develop."
  exit 1
fi

echo "✅ Commit message validation passed!"
